{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist-electron",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "typeRoots": ["../tui/node_modules/@types"],
    "types": ["node"]
  },
  "include": ["electron-main/**/*.ts", "src/shims.d.ts"]
}
